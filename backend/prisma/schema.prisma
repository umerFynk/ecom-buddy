  content         String
  category        String?
  embeddingVector Float[]  @map("embedding_vector")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_knowledge_base")
}

// ===========================================================
// WMS 3PL
// ===========================================================

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  zones            WarehouseZone[]
  inboundShipments InboundShipment[]
  pickTasks        PickTask[]

  @@map("warehouses")
}

model WarehouseZone {
  id          String  @id @default(cuid())
  warehouseId String  @map("warehouse_id")
  zoneCode    String  @map("zone_code")
  name        String

  warehouse Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locations WarehouseLocation[]

  @@unique([warehouseId, zoneCode])
  @@map("warehouse_zones")
}

model WarehouseLocation {
  id      String  @id @default(cuid())
  zoneId  String  @map("zone_id")
  shelf   String
  bin     String
  barcode String  @unique

  zone         WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  skuLocations SkuLocation[]
  pickTaskItems PickTaskItem[]

  @@unique([zoneId, shelf, bin])
  @@map("warehouse_locations")
}

model SkuLocation {
  id         String @id @default(cuid())
  variantId  String @map("variant_id")
  locationId String @map("location_id")
  quantity   Int    @default(0)

  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([variantId, locationId])
  @@map("sku_locations")
}

model InboundShipment {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  warehouseId   String        @map("warehouse_id")
  grnNumber     String        @unique @map("grn_number")
  status        InboundStatus @default(pending)
  expectedAt    DateTime?     @map("expected_at")
  receivedAt    DateTime?     @map("received_at")
  totalExpected Int           @default(0) @map("total_expected")
  totalReceived Int           @default(0) @map("total_received")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  items     InboundItem[]

  @@index([tenantId, status])
  @@map("inbound_shipments")
}

model InboundItem {
  id          String  @id @default(cuid())
  inboundId   String  @map("inbound_id")
  variantId   String  @map("variant_id")
  expectedQty Int     @map("expected_qty")
  receivedQty Int     @default(0) @map("received_qty")
  condition   String? // good | damaged | unsellable
  photoUrl    String? @map("photo_url")

  inbound InboundShipment @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  variant ProductVariant  @relation(fields: [variantId], references: [id])

  @@index([inboundId])
  @@map("inbound_items")
}

model PickTask {
  id           String         @id @default(cuid())
  orderId      String         @map("order_id")
  warehouseId  String         @map("warehouse_id")
  assignedToId String?        @map("assigned_to")
  status       PickTaskStatus @default(pending)
  createdAt    DateTime       @default(now()) @map("created_at")
  startedAt    DateTime?      @map("started_at")
  completedAt  DateTime?      @map("completed_at")

  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  items     PickTaskItem[]

  @@index([assignedToId, status])
  @@map("pick_tasks")
}

model PickTaskItem {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  variantId   String   @map("variant_id")
  locationId  String?  @map("location_id")
  qtyRequired Int      @map("qty_required")
  qtyPicked   Int      @default(0) @map("qty_picked")
  scannedAt   DateTime? @map("scanned_at")

  task     PickTask           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  variant  ProductVariant     @relation(fields: [variantId], references: [id])
  location WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("pick_task_items")
}

model PackTask {
  id           String         @id @default(cuid())
  orderId      String         @map("order_id")
  assignedToId String?        @map("assigned_to")
  weightKg     Decimal?       @db.Decimal(10, 3) @map("weight_kg")
  photoUrl     String?        @map("photo_url")
  status       PackTaskStatus @default(pending)
  startedAt    DateTime?      @map("started_at")
  completedAt  DateTime?      @map("completed_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([assignedToId, status])
  @@map("pack_tasks")
}

model RtoWarehouseReceipt {
  id            String       @id @default(cuid())
  orderId       String       @map("order_id")
  receivedAt    DateTime     @default(now()) @map("received_at")
  condition     RtoCondition
  restockedQty  Int          @default(0) @map("restocked_qty")
  writeOffQty   Int          @default(0) @map("write_off_qty")
  photoUrl      String?      @map("photo_url")
  notes         String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("rto_warehouse_receipts")
}

// ===========================================================
// B2B COMMUNICATION
// ===========================================================

model B2bConversation {
  id                String     @id @default(cuid())
  tenantId          String     @map("tenant_id")
  accountManagerId  String?    @map("account_manager_id")
  ticketId          String?    @unique @map("ticket_id")
  status            String     @default("open") // open | resolved
  lastMessageAt     DateTime   @default(now()) @map("last_message_at")
  createdAt         DateTime   @default(now()) @map("created_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountManager AdminUser?     @relation(fields: [accountManagerId], references: [id], onDelete: SetNull)
  ticket         SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  messages       B2bMessage[]

  @@index([tenantId, status])
  @@map("b2b_conversations")
}

model B2bMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderType     String   @map("sender_type") // reseller_user | admin
  senderId       String   @map("sender_id")
  content        String
  attachmentUrl  String?  @map("attachment_url")
  sentAt         DateTime @default(now()) @map("sent_at")
  readAt         DateTime? @map("read_at")

  conversation B2bConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@map("b2b_messages")
}

model B2bBroadcast {
  id              String                @id @default(cuid())
  sentByAdminId   String                @map("sent_by")
  audienceType    BroadcastAudienceType @default(all) @map("audience_type")
  audienceFilter  Json?                 @map("audience_filter_json")
  message         String
  sentCount       Int                   @default(0) @map("sent_count")
  sentAt          DateTime              @default(now()) @map("sent_at")

  @@index([sentAt])
  @@map("b2b_broadcasts")
}

// ===========================================================
// PLATFORM
// ===========================================================

model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedById String? @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

model OosEvent {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  storeId             String    @map("store_id")
  variantId           String    @map("variant_id")
  triggeredAt         DateTime  @default(now()) @map("triggered_at")
  affectedOrdersCount Int       @default(0) @map("affected_orders_count")
  sellerNotifiedAt    DateTime? @map("seller_notified_at")
  adminNotifiedAt     DateTime? @map("admin_notified_at")
  resolvedAt          DateTime? @map("resolved_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId, resolvedAt])
  @@map("oos_events")
}

// ===========================================================
// CSV IMPORTS (audit log for bulk order uploads)
// ===========================================================

enum CsvImportStatus {
  preview
  committed
  cancelled
  expired
}

model CsvImport {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  storeId         String          @map("store_id")
  uploadedById    String          @map("uploaded_by")
  filename        String
  totalRows       Int             @default(0) @map("total_rows")
  validRows       Int             @default(0) @map("valid_rows")
  invalidRows     Int             @default(0) @map("invalid_rows")
  committedRows   Int             @default(0) @map("committed_rows")
  status          CsvImportStatus @default(preview)
  previewSummary  Json?           @map("preview_summary_json")
  errorReport     Json?           @map("error_report_json")
  committedAt     DateTime?       @map("committed_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("csv_imports")
}

// ===========================================================
// WEBHOOK IDEMPOTENCY (Shopify webhooks)
// ===========================================================

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String   // shopify | courier_postex | ...
  externalId  String   @map("external_id") // header X-Shopify-Webhook-Id
  topic       String?
  receivedAt  DateTime @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")
  error       String?

  @@unique([source, externalId])
  @@index([source, topic])
  @@map("webhook_events")
}
