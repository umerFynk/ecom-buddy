// Ecom Buddy — full Prisma schema (Part 26 of BLUEPRINT.md).
// Every reseller-owned row carries tenantId. Order statuses are stored as
// strings (not enums) because admins manage them via Status Manager UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Plan {
  starter
  growth
  scale
}

enum ResellerRole {
  owner
  manager
  cs_agent
  viewer
}

enum AdminRole {
  super_admin
  account_manager
  cs_agent
  warehouse
}

enum CourierType {
  postex
  leopards
  trax
  blueex
  mnx
  callcourier
}

enum DispatchMode {
  self
  ecombuddy_3pl
  ecombuddy_courier_account
}

enum ConfirmationMode {
  off
  manual
  ai_engine
}

enum OrderSource {
  shopify
  shopify_poll
  csv_import
  manual
  api
}

enum PaymentStatus {
  cod
  prepaid
}

enum CodRemittanceStatus {
  pending
  paid
  short
  unknown
}

enum BlacklistLevel {
  clean
  watch
  high_risk
  blacklisted
  global
}

enum ApiKeyScope {
  read_only
  orders
  full_access
}

enum WaSystem {
  customer
  b2b
  shared
}

enum WaDirection {
  inbound
  outbound
}

enum WaMessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum CsConversationStatus {
  open
  ai_handling
  cs_handling
  resolved
}

enum InventoryMovementType {
  inbound
  outbound
  allocation
  deallocation
  adjustment
  rto_restock
  damage
  write_off
}

enum TicketStatus {
  open
  in_progress
  waiting_on_reseller
  resolved
  closed
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum BroadcastAudienceType {
  all
  segment
  manual
}

enum InboundStatus {
  pending
  in_transit
  arrived
  receiving
  received
  discrepancy
  cancelled
}

enum PickTaskStatus {
  pending
  in_progress
  completed
  partial
  cancelled
}

enum PackTaskStatus {
  pending
  in_progress
  packed
  cancelled
}

enum RtoCondition {
  good
  damaged
  unsellable
}

enum NotificationChannel {
  whatsapp
  email
  inapp
}

enum StatusType {
  active
  failure
  cancellation
  special
  terminal
}

enum RevenueRecognitionMode {
  cash_basis
  accrual_delivered
  accrual_dispatched
}

enum AppealStatus {
  pending
  approved
  rejected
}

// ===========================================================
// AUTH & TENANTS
// ===========================================================

model Tenant {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  prefix        String   @unique // EB-{PREFIX}-... in SKUs
  plan          Plan     @default(starter)
  trialEndsAt   DateTime? @map("trial_ends_at")
  settings      Json     @default("{}") @map("settings_json")
  isActive      Boolean  @default(true) @map("is_active")
  threePlEnabled Boolean @default(false) @map("three_pl_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  stores                  Store[]
  users                   User[]
  apiKeys                 ApiKey[]
  products                Product[]
  inventoryLevels         InventoryLevel[]
  customers               Customer[]
  orders                  Order[]
  courierConfigs          CourierConfig[]
  shipments               Shipment[]
  waMessages              WaMessage[]
  waTemplates             WaTemplate[]
  campaigns               Campaign[]
  csConversations         CsConversation[]
  financials              Financial[]
  courierStatements       CourierStatement[]
  remittances             Remittance[]
  loadSheets              LoadSheet[]
  shipperAdvice           ShipperAdvice[]
  picklists               Picklist[]
  riskEngineConfig        RiskEngineConfig?
  riskCustomRules         RiskCustomRule[]
  automationRules         AutomationRule[]
  notificationSettings    NotificationSetting[]
  notifications           Notification[]
  supportTickets          SupportTicket[]
  aiConversations         AiConversation[]
  inboundShipments        InboundShipment[]
  blacklistLogs           BlacklistLog[]
  blacklistOverrides      BlacklistOverride[]
  oosEvents               OosEvent[]
  b2bConversations        B2bConversation[]

  @@index([plan])
  @@index([isActive])
  @@map("tenants")
}

model Store {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  name              String
  shopifyDomain     String?          @map("shopify_domain") // e.g. shop.myshopify.com
  shopifyToken      String?          @map("shopify_token") // encrypted
  shopifyScope      String?          @map("shopify_scope")
  shopifyInstalledAt DateTime?       @map("shopify_installed_at")
  fieldMapping      Json             @default("{}") @map("field_mapping_json")
  dispatchMode      DispatchMode     @default(self) @map("dispatch_mode")
  confirmationMode  ConfirmationMode @default(manual) @map("confirmation_mode")
  wmsEnabled        Boolean          @default(false) @map("wms_enabled")
  brandColor        String?          @map("brand_color")
  logoUrl           String?          @map("logo_url")
  customDomain      String?          @map("custom_domain")
  hideEbBranding    Boolean          @default(false) @map("hide_eb_branding")
  reviewLink        String?          @map("review_link")
  timezone          String           @default("Asia/Karachi")
  businessHoursStart String?         @map("business_hours_start")
  businessHoursEnd   String?         @map("business_hours_end")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products        Product[]
  inventoryLevels InventoryLevel[]
  orders          Order[]
  oosEvents       OosEvent[]

  @@unique([tenantId, shopifyDomain])
  @@index([tenantId])
  @@map("stores")
}

model User {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  email         String
  passwordHash  String       @map("password_hash")
  name          String?
  role          ResellerRole @default(viewer)
  lastLoginAt   DateTime?    @map("last_login_at")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  csMessagesSent CsMessage[]
  ticketsAssigned SupportTicket[] @relation("TicketAssignedReseller")

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

model ApiKey {
  id          String      @id @default(cuid())
  tenantId    String      @map("tenant_id")
  name        String
  prefix      String      @unique // first 8 chars shown to user
  keyHash     String      @unique @map("key_hash")
  scope       ApiKeyScope @default(read_only)
  rateLimit   Int         @default(1000) @map("rate_limit") // per hour
  lastUsedAt  DateTime?   @map("last_used_at")
  expiresAt   DateTime?   @map("expires_at")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model AdminUser {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  name          String?
  role          AdminRole  @default(cs_agent)
  twoFactorSecret String?  @map("2fa_secret")
  isActive      Boolean    @default(true) @map("is_active")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  ticketsAssigned   SupportTicket[]    @relation("TicketAssignedAdmin")
  b2bConversations  B2bConversation[]
  internalChannels  InternalChannel[]
  internalDmsSent   InternalDirectMessage[] @relation("DmFrom")
  internalDmsRcvd   InternalDirectMessage[] @relation("DmTo")
  internalMessages  InternalMessage[]
  channelMembers    InternalChannelMember[]
  csConversationsAssigned CsConversation[]

  @@index([role])
  @@map("admin_users")
}

// ===========================================================
// PRODUCTS & SKUs
// ===========================================================

model Product {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  storeId          String   @map("store_id")
  shopifyProductId String?  @map("shopify_product_id")
  title            String
  cogs             Decimal? @db.Decimal(12, 2)
  imageUrl         String?  @map("image_url")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@unique([tenantId, storeId, shopifyProductId])
  @@index([tenantId])
  @@map("products")
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String   @map("product_id")
  sku               String
  shopifyVariantId  String?  @map("shopify_variant_id")
  shopifySku        String?  @map("shopify_sku") // SKU originally from Shopify before our gen
  title             String?
  variantTitle      String?  @map("variant_title")
  price             Decimal? @db.Decimal(12, 2)
  cogs              Decimal? @db.Decimal(12, 2)
  weightGrams       Int?     @map("weight_grams")
  pushedToShopifyAt DateTime? @map("pushed_to_shopify_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLevels   InventoryLevel[]
  inventoryMovements InventoryMovement[]
  orderItems        OrderItem[]
  inboundItems      InboundItem[]
  pickTaskItems     PickTaskItem[]
  skuLocations      SkuLocation[]
  picklistItems     PicklistItem[]
  oosEvents         OosEvent[]

  @@index([sku])
  @@index([productId])
  @@map("product_variants")
}

model InventoryLevel {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  variantId           String   @map("variant_id")
  storeId             String   @map("store_id")
  totalStock          Int      @default(0) @map("total_stock")
  allocatedStock      Int      @default(0) @map("allocated_stock")
  lowStockThreshold   Int      @default(5) @map("low_stock_threshold")
  lastSyncedAt        DateTime? @map("last_synced_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([variantId, storeId])
  @@index([tenantId])
  @@map("inventory_levels")
}

model InventoryMovement {
  id        String                @id @default(cuid())
  variantId String                @map("variant_id")
  type      InventoryMovementType
  quantity  Int
  orderId   String?               @map("order_id")
  reason    String?
  batchId   String?               @map("batch_id")
  createdAt DateTime              @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId, createdAt])
  @@index([orderId])
  @@map("inventory_movements")
}

// ===========================================================
// CUSTOMERS
// ===========================================================

model Customer {
  id                   String         @id @default(cuid())
  tenantId             String         @map("tenant_id")
  phoneNormalized      String         @map("phone_normalized")
  name                 String?
  email                String?
  totalOrders          Int            @default(0) @map("total_orders")
  deliveredCount       Int            @default(0) @map("delivered_count")
  returnedCount        Int            @default(0) @map("returned_count")
  cancelledCount       Int            @default(0) @map("cancelled_count")
  deliverySuccessRate  Decimal?       @db.Decimal(5, 2) @map("delivery_success_rate")
  blacklistLevel       BlacklistLevel @default(clean) @map("blacklist_level")
  isVip                Boolean        @default(false) @map("is_vip")
  tags                 String[]
  notes                String?
  lastOrderAt          DateTime?      @map("last_order_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]
  blacklistLogs    BlacklistLog[]
  blacklistOverrides BlacklistOverride[]
  blacklistAppeals BlacklistAppeal[]
  csConversations  CsConversation[]
  campaignRecipients CampaignRecipient[]

  @@unique([tenantId, phoneNormalized])
  @@index([phoneNormalized]) // global lookup for blacklist
  @@map("customers")
}

model BlacklistLog {
  id         String         @id @default(cuid())
  customerId String         @map("customer_id")
  tenantId   String         @map("tenant_id")
  level      BlacklistLevel
  reason     String?
  actorId    String?        @map("actor_id")
  actorType  String         @default("system") @map("actor_type") // system | reseller_user | admin
  createdAt  DateTime       @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tenantId])
  @@map("blacklist_log")
}

model BlacklistOverride {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  tenantId   String   @map("tenant_id")
  orderId    String?  @map("order_id")
  reason     String
  actorId    String   @map("actor_id")
  outcome    String?  // delivered | rto | pending
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([tenantId])
  @@map("blacklist_overrides")
}

model BlacklistAppeal {
  id                String       @id @default(cuid())
  customerId        String       @map("customer_id")
  appellantTenantId String       @map("appellant_tenant_id")
  reason            String
  evidenceUrl       String?      @map("evidence_url")
  status            AppealStatus @default(pending)
  adminDecision     String?      @map("admin_decision")
  adminId           String?      @map("admin_id")
  resolvedAt        DateTime?    @map("resolved_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([customerId])
  @@map("blacklist_appeals")
}

// ===========================================================
// ORDERS
// ===========================================================

model Order {
  id                    String              @id @default(cuid())
  tenantId              String              @map("tenant_id")
  storeId               String              @map("store_id")
  source                OrderSource         @default(manual)
  shopifyOrderId        String?             @map("shopify_order_id")
  shopifyOrderNumber    String?             @map("shopify_order_number")
  externalRef           String?             @map("external_ref")
  status                String              @default("new")
  confirmationStatus    String?             @map("confirmation_status") // pending | confirmed | otp_sent | refused | cs_review
  riskScore             Int?                @map("risk_score")
  riskFlags             String[]            @map("risk_flags")
  riskBreakdown         Json?               @map("risk_breakdown")
  customerId            String?             @map("customer_id")
  customerName          String              @map("customer_name")
  phone                 String
  alternatePhone        String?             @map("alternate_phone")
  email                 String?
  city                  String
  province              String?
  addressLine1          String              @map("address_line_1")
  addressLine2          String?             @map("address_line_2")
  postalCode            String?             @map("postal_code")
  country               String              @default("PK")
  amount                Decimal             @db.Decimal(12, 2)
  currency              String              @default("PKR")
  discount              Decimal?            @db.Decimal(12, 2)
  shippingFee           Decimal?            @db.Decimal(12, 2) @map("shipping_fee")
  paymentStatus         PaymentStatus       @default(cod) @map("payment_status")
  weightGrams           Int?                @map("weight_grams")
  itemCount             Int                 @default(0) @map("item_count")
  orderNote             String?             @map("order_note")
  metadata              Json                @default("{}")
  courierType           CourierType?        @map("courier_type")
  courierConfigId       String?             @map("courier_config_id")
  trackingNumber        String?             @map("tracking_number")
  labelUrl              String?             @map("label_url")
  confirmedAt           DateTime?           @map("confirmed_at")
  dispatchedAt          DateTime?           @map("dispatched_at")
  deliveredAt           DateTime?           @map("delivered_at")
  rtoAt                 DateTime?           @map("rto_at")
  cancelledAt           DateTime?           @map("cancelled_at")
  cancelReason          String?             @map("cancel_reason")
  codRemittanceStatus   CodRemittanceStatus @default(pending) @map("cod_remittance_status")
  codAmountExpected     Decimal?            @db.Decimal(12, 2) @map("cod_amount_expected")
  codAmountReceived     Decimal?            @db.Decimal(12, 2) @map("cod_amount_received")
  codPaidAt             DateTime?           @map("cod_paid_at")
  isOnHold              Boolean             @default(false) @map("is_on_hold")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  courierConfig CourierConfig?   @relation(fields: [courierConfigId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  events       OrderEvent[]
  metadataRows OrderMetadata[]
  confirmationLogs ConfirmationLog[]
  shipments    Shipment[]
  financial    Financial?
  inventoryMovements InventoryMovement[]
  packingSlips PackingSlip[]
  loadSheetOrders LoadSheetOrder[]
  blacklistOverrides BlacklistOverride[]
  pickTasks    PickTask[]
  packTasks    PackTask[]
  rtoReceipts  RtoWarehouseReceipt[]
  notifications Notification[]
  remittanceRows RemittanceRow[]
  courierStatementRows CourierStatementRow[]
  supportTickets SupportTicket[]

  @@unique([tenantId, storeId, shopifyOrderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([phone])
  @@index([trackingNumber])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  variantId    String?  @map("variant_id")
  title        String
  sku          String?
  quantity     Int
  allocatedQty Int      @default(0) @map("allocated_qty")
  price        Decimal  @db.Decimal(12, 2)
  cogs         Decimal? @db.Decimal(12, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

// IMMUTABLE — never delete rows. Append-only audit log of every status change.
model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  fromStatus String? @map("from_status")
  toStatus  String   @map("to_status")
  actorType String   @map("actor_type") // system | reseller_user | admin | courier_webhook | shopify
  actorId   String?  @map("actor_id")
  note      String?
  metadata  Json?    @map("metadata_json")
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_events")
}

model OrderMetadata {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  key     String
  value   String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, key])
  @@index([orderId])
  @@map("order_metadata")
}

// ===========================================================
// CONFIRMATION
// ===========================================================

model ConfirmationLog {
  id           String    @id @default(cuid())
  orderId      String    @map("order_id")
  pathUsed     String    @map("path_used") // A | B | C | D | E | ai_engine
  modeUsed     ConfirmationMode @map("mode_used")
  waMessageId  String?   @map("wa_message_id")
  sentAt       DateTime? @map("sent_at")
  repliedAt    DateTime? @map("replied_at")
  replyText    String?   @map("reply_text")
  outcome      String?   // confirmed | refused | timeout | cancelled | hold | shipped_anyway
  otpCode      String?   @map("otp_code")
  otpExpiresAt DateTime? @map("otp_expires_at")
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("confirmation_logs")
}

// ===========================================================
// COURIERS
// ===========================================================

model CourierConfig {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  courierType       CourierType @map("courier_type")
  accountName       String?     @map("account_name")
  accountNo         String?     @map("account_no")
  apiKeyEncrypted   String      @map("api_key_encrypted")
  apiPasswordEncrypted String?  @map("api_password_encrypted")
  pickupAddress     Json?       @map("pickup_address")
  priority          Int         @default(100)
  successRate7d     Decimal?    @db.Decimal(5, 2) @map("success_rate_7d")
  cityOverrides     Json        @default("{}") @map("city_overrides_json")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipments Shipment[]
  orders    Order[]
  loadSheets LoadSheet[]

  @@unique([tenantId, courierType, accountNo])
  @@index([tenantId])
  @@map("courier_configs")
}

model CourierStatusMap {
  id            String      @id @default(cuid())
  courierType   CourierType @map("courier_type")
  rawStatus     String      @map("raw_status")
  masterStatus  String      @map("master_status")
  mappedBy      String?     @map("mapped_by") // admin user id
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([courierType, rawStatus])
  @@map("courier_status_maps")
}

model CourierStatusUnmapped {
  id          String      @id @default(cuid())
  courierType CourierType @map("courier_type")
  rawStatus   String      @map("raw_status")
  orderId     String?     @map("order_id")
  receivedAt  DateTime    @default(now()) @map("received_at")
  resolvedAt  DateTime?   @map("resolved_at")

  @@index([courierType, rawStatus])
  @@map("courier_status_unmapped")
}

model Shipment {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  orderId         String   @map("order_id")
  courierConfigId String   @map("courier_config_id")
  trackingNumber  String   @map("tracking_number")
  labelUrl        String?  @map("label_url")
  bookedAt        DateTime @default(now()) @map("booked_at")
  currentStatus   String   @map("current_status")
  statusHistory   Json     @default("[]") @map("status_history_json")
  weightKg        Decimal? @db.Decimal(10, 3) @map("weight_kg")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
